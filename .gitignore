# Stray local Python venv left over from early exploration — not part of
# the monorepo layout (backend/ + frontend/); never commit it.
/litlist/

# --- Backend (Python) ---
backend/.venv/
backend/venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
backend/litlist_dev.db
*.db
*.db-journal
# WAL-mode sidecar files (app/db.py's local-SQLite concurrency fix) —
# these are appended to the filename, not a `.db`-suffixed name, so the
# `*.db` glob above doesn't match them. Long-lived for the engine's whole
# process lifetime and hold real uncommitted session/queue data.
*.db-wal
*.db-shm
.env
backend/.env

# --- Frontend (Node/Vite) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
frontend/.lighthouseci/
*.local
node_modules/

# --- Editor / OS ---
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
