# Copy to .env for local dev. None of these are required for local SQLite dev
# (db.py falls back to a local file automatically) — set TURSO_* to point at a
# real Turso database instead (see BuildPlan.md Task 5A).

# --- Database (app/db.py) ---
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
LOCAL_SQLITE_PATH=./litlist_dev.db

# --- PubMed (Task 1B) ---
NCBI_API_KEY=
NCBI_TOOL=litlist
NCBI_EMAIL=

# --- Zotero (Task 1C, SPEC.md §8.2/§8.3) ---
# Register LitList at https://www.zotero.org/oauth/apps to get these. Left
# blank in dev/CI — Task 1C's automated tests mock the OAuth 1.0a provider
# and pyzotero calls, so no live value is required to run the suite.
ZOTERO_CLIENT_KEY=
ZOTERO_CLIENT_SECRET=
# Fixed, non-dynamic callback URL pre-registered with Zotero (§8.2's
# open-redirect fix) — must exactly match what's registered in the Zotero
# developer console for the target deployment.
ZOTERO_CALLBACK_URL=http://localhost:8000/api/v1/zotero/auth/callback
# Fixed in-app path the user is bounced to once the handshake completes.
ZOTERO_POST_AUTH_REDIRECT_URL=http://localhost:5173/?zotero=connected

# --- Session/security (Task 1A, SPEC.md §9.1/§9.6/§10.2) ---
# Both of these are dev-only placeholders you generate yourself locally —
# never hand-write a value, never commit a real value anywhere (including
# here), and never ask another human for one; they're not shared secrets,
# they're per-deployment. If left unset, the backend generates an ephemeral
# in-process key at startup (with a logged warning) so local dev/tests still
# work out of the box — fine for a throwaway local DB, NOT fine for any
# deployment that needs encrypted data to survive a process restart, since a
# fresh ephemeral key can't decrypt data written under a previous one.
#
# Generate TOKEN_ENCRYPTION_KEY (Fernet key, used to encrypt/decrypt
# ZoteroConnection.oauth_token / oauth_token_secret at the application layer,
# §9.6 — deliberately a separate secret from the Turso DB credentials):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Generate SESSION_COOKIE_SECRET (HMAC key used to sign the session_id cookie
# value so a tampered/forged cookie is rejected before it ever reaches a DB
# lookup, §10.2):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_COOKIE_SECRET=
TOKEN_ENCRYPTION_KEY=

# --- CORS allow-list (Task 3D, SPEC.md §10.7) ---
# Comma-separated list of the frontend's real, deployed origin(s) — this
# is LitList's main CSRF defense (§10.7), so it must stay an explicit
# allow-list, never a wildcard. Defaults to the local Vite dev server if
# unset; Task 5A's deployment must set this to the real static-hosted
# frontend origin(s) instead.
FRONTEND_ORIGINS=http://localhost:5173
